# Telegram Bot Token
# Get it from @BotFather in Telegram
# TELEGRAM_TOKEN=1234567890:AAE...your_bot_token_here...

# HTTP/HTTPS/SOCKS Proxy (optional)
# Leave empty for direct connection
# PROXY_URL=http://proxy_host:proxy_port

# Интервал напоминания в минутах (по умолчанию 10)
# REMINDER_MINUTES=10

# Директория для логов (по умолчанию logs/)
# LOG_DIR=logs
